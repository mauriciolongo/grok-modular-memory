{
  "description": "Modular project memory system. Note: As of May 2026, SessionStart hook injection is not yet supported by the platform. The root AGENTS.md provides the reliable memory loading. This file keeps the full hook set for future compatibility. Reminders on Stop/PreCompact and session-end timestamping are functional.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "session-start.py",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "session-end.py",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "memory-reminder.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "memory-reminder.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
